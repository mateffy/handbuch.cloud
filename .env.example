# Cloudflare R2 credentials for DB upload during build.
#
# Uses 1Password CLI secret references (op:// URIs) — no real secrets on disk.
# Run builds via: bun run build:content  (calls `op run --env-file=.env` internally)
# or directly:    op run --env-file=.env -- bun run scripts/build-content.ts
#
# To find the correct op:// URI: right-click any field in 1Password → Copy Secret Reference
# URI format: op://vault-name/item-name/field-name
#
# Set up a new item in 1Password (e.g. "Handbuch R2") with these fields:
#   account_id       → Cloudflare dashboard → right sidebar → Account ID
#   access_key_id    → R2 → Manage API Tokens → token Access Key ID
#   secret_access_key → R2 → Manage API Tokens → token Secret Access Key

R2_ACCOUNT_ID=op://Private/Handbuch R2/account_id
R2_ACCESS_KEY_ID=op://Private/Handbuch R2/access_key_id
R2_SECRET_ACCESS_KEY=op://Private/Handbuch R2/secret_access_key

# Plain values — not sensitive, fine to hardcode
R2_BUCKET=handbuch-db
R2_PUBLIC_URL=https://db.handbuch.cloud
